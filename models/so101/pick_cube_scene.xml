<mujoco model="pick_cube_scene">
    <include file="so101_new_calib.xml" />

    <option timestep="0.002" gravity="0 0 -9.81" noslip_iterations="3" impratio="10" cone="elliptic"/>

    <default>
        <geom solref="0.001 1" solimp="0.99 0.99 0.001"/>
    </default>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="90" elevation="-20" />
        <!-- znear=0.005 very small to avoid clipping through finger meshes -->
        <map znear="0.005" />
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
        <material name="cube_material" rgba="0.9 0.1 0.1 1" />  <!-- red cube to match IRL -->
        <material name="container_material" rgba="0.2 0.6 0.2 1" />  <!-- green container -->
    </asset>

    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

        <!-- Container at (0.25, 0.15): 8x8cm inner, 3cm tall, wall thickness 0.5cm -->
        <body name="container" pos="0.40 0.10 0.04">
            <!-- floor -->
            <geom name="container_floor" type="box" size="0.045 0.045 0.002" pos="0 0 0.002" material="container_material" contype="1" conaffinity="1"/>
            <!-- front wall -->
            <geom name="container_wall_front" type="box" size="0.045 0.0025 0.015" pos="0 0.0475 0.017" material="container_material" contype="1" conaffinity="1"/>
            <!-- back wall -->
            <geom name="container_wall_back" type="box" size="0.045 0.0025 0.015" pos="0 -0.0475 0.017" material="container_material" contype="1" conaffinity="1"/>
            <!-- left wall -->
            <geom name="container_wall_left" type="box" size="0.0025 0.045 0.015" pos="-0.0475 0 0.017" material="container_material" contype="1" conaffinity="1"/>
            <!-- right wall -->
            <geom name="container_wall_right" type="box" size="0.0025 0.045 0.015" pos="0.0475 0 0.017" material="container_material" contype="1" conaffinity="1"/>
        </body>

        <!-- Cube to pick up: 3x3x3cm (sized to fit gripper gap) -->
        <body name="cube" pos="0.40 -0.10 0.015">
            <freejoint name="cube_joint"/>
            <geom name="cube_geom" type="box" size="0.015 0.015 0.015" mass="0.03" material="cube_material" friction="0.5 0.05 0.001"/>  <!-- wood friction -->
        </body>
    </worldbody>

    <sensor>
        <!-- Cube position -->
        <framepos name="cube_pos" objtype="body" objname="cube" />
        <!-- Gripper TCP position (10cm in front of gripper) -->
        <framepos name="gripper_pos" objtype="site" objname="gripperframe" />
        <!-- Grasp point position (between fingers, for reach reward) -->
        <framepos name="grasp_pos" objtype="site" objname="graspframe" />
    </sensor>
</mujoco>
